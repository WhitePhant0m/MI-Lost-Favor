	quest.53CBB401AAEFD083.quest_desc: ["Подавая сурс и банку с мобами, можно делать жертоприношение для мода окультизм, если поставить под алтарём"]
	quest.53D189F7EF7CD121.quest_subtitle: "Perform the ritual!"
	quest.53D226046704B4F5.quest_desc: [
		"Same as copper, but with a small chance to catch gold and iron."
		"{@pagebreak}"
		"То же самое, что и медная, но с небольшой вероятностью добычи золота и железа."
	]
	quest.552B1FFCECBD0652.quest_desc: [
		"A manual well. Produces different amounts of water in different biomes. Can be connected to a system of aqueducts"
		"{@pagebreak}"
		"Ручной колодец. Производит разное количество воды в разных биомах. Может быть подключен к системе акведуков."
	]
	quest.5554B53144E7F2C5.quest_desc: ["Right-click on a fully grown crop to replant it with the power of worm-friendship!"]
	quest.556305C2A39D9127.quest_desc: [
		"Gathers item entities within its radius and attempts to store them in an adjacent container (excluding the container directly below the pyre)."
		""
		"{@pagebreak}"
